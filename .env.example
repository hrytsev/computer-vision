# Application Settings
APP_NAME=ResNet Fracture API
APP_VERSION=1.0.0
DEBUG=False

# Server Settings
HOST=0.0.0.0
PORT=8001

# CORS Settings
# Comma-separated list of allowed origins (no spaces)
# Example: CORS_ORIGINS=http://localhost:3000,https://example.com
# For development, you might use: CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# For production, specify your actual frontend domains
CORS_ORIGINS=
CORS_METHODS=GET,POST
CORS_HEADERS=Content-Type,Authorization

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Image Validation
MAX_IMAGE_SIZE_MB=10.0
ALLOWED_IMAGE_FORMATS=image/jpeg,image/png

# Model Settings
MODEL_PATH=models/resnet18_fractured/resnet18_fractured.pth
DEVICE=cpu

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Cache Settings
CACHE_TTL=60
